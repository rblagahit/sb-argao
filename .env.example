# ─────────────────────────────────────────────────────────────────────────────
# Firebase Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Firebase project credentials
# Found in: Firebase Console → Project Settings → Your Apps → SDK setup
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
# Optional for the shelved local-folder upload feature.
# When you are ready to enable managed file storage, set:
# VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# LGU identifier used in Firestore paths (e.g., lgus/{LGU_ID}/...)
VITE_LGU_ID=your-lgu-id

# Firebase App Check — reCAPTCHA v3 site keys (public, one per Firebase project)
# Register site keys at: https://www.google.com/recaptcha/admin/create (type: reCAPTCHA v3)
# Then register in: Firebase Console → App Check → Apps → Register
# The app selects the right key by hostname at runtime (see index.html _appCheckKeys).
# In dev (localhost), App Check is skipped automatically — no key needed.
VITE_RECAPTCHA_KEY_MULTI=your-recaptcha-v3-key-for-multi-legislative
VITE_RECAPTCHA_KEY_SB=your-recaptcha-v3-key-for-sb-argao
