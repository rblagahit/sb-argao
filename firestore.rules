rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public data — anyone can read; authenticated admins can write
    match /artifacts/{appId}/public/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Admin data — only authenticated admins can read/write
    match /artifacts/{appId}/admin/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
